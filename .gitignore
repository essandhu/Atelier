# dependencies
node_modules/
.pnpm-store/

# git worktrees
.worktrees/

# next.js
.next/
out/
next-env.d.ts

# production
build/

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# local env
.env
.env.local
.env.*.local

# vercel
.vercel

# typescript
*.tsbuildinfo

# test output
coverage/
playwright-report/
test-results/
playwright/.cache/

# editors
.idea/
.vscode/*
!.vscode/settings.json.example

# sentry
.sentryclirc

# generated asset artifacts (keep source glbs/ktx2 out of git, build artifacts excluded)
public/scene/**/*.draco.glb
# Artist-delivered interactive GLBs live here; the source .blend is not
# version-controlled and the delivered .glb is treated the same way.
# Validation still runs against them in CI on machines that have them.
public/scene/models/*.glb
# GitHub avatar — fetched at build time by scripts/fetch-github-avatar.mjs.
# WallPiece falls back to GithubSnapshot.avatarUrl (the public redirect)
# when this file is missing, so the absence of a checked-in binary is safe.
public/scene/avatar.jpg

# texture-compression staging area (developer-local source files)
assets-src/

# Keep visual regression baselines tracked per ADR-011
!tests/e2e/visual/baseline/*.png

# docs — local-only working notes; not shipped publicly.
docs/

# Claude Code workspace state (scheduled tasks, worktree metadata, etc.)
.claude/
