# GitHub PAT with `read:user` scope. Used by src/data/github/client.ts.
GITHUB_PAT=

# GitHub username for contribution + activity queries.
GITHUB_USERNAME=

# Sentry — optional. If absent, Sentry init is a no-op.
NEXT_PUBLIC_SENTRY_DSN=

# Sentry auth token for source-map upload (CI only).
SENTRY_AUTH_TOKEN=

# Shared secret for POST /api/revalidate.
REVALIDATE_SECRET=

# Log level: fatal, error, warn, info, debug, trace.
LOG_LEVEL=info
