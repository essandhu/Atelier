{
  "name": "atelier",
  "version": "0.1.0",
  "private": true,
  "description": "Atelier — a spatial, cinematic developer portfolio.",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0 <21.0.0 || >=22.0.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "lh:night": "pnpm dlx @lhci/cli@0.13.x autorun",
    "assets:build": "node scripts/asset-pipeline/compress-geometry.mjs && node scripts/asset-pipeline/compress-textures.mjs",
    "assets:verify": "node scripts/asset-pipeline/verify-budgets.mjs",
    "bundle:verify": "node scripts/asset-pipeline/verify-bundle-size.mjs"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.34",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-three/drei": "^10.0.0",
    "@react-three/fiber": "^9.0.0",
    "@react-three/postprocessing": "^3.0.0",
    "@sentry/nextjs": "^8.47.0",
    "@vercel/analytics": "^1.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "next": "^15.1.3",
    "pino": "^9.5.0",
    "postprocessing": "^6.36.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^2.5.5",
    "three": "^0.170.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@gltf-transform/cli": "^4.1.1",
    "@gltf-transform/core": "^4.1.1",
    "@gltf-transform/functions": "^4.1.1",
    "@playwright/test": "^1.49.1",
    "@tailwindcss/postcss": "^4.2.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^20.17.10",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/three": "^0.170.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "eslint-config-prettier": "^9.1.0",
    "happy-dom": "^15.11.7",
    "only-allow": "^1.2.1",
    "pino-pretty": "^13.0.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
